<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <section class="p-4 border rounded shadow-sm bg-light">
        <h4 class="mb-3 text-center">Wing</h4>

        <%= form_with(model: wing) do |form| %>
          <% if wing.errors.any? %>
            <div class="alert alert-danger">
              <h5><%= pluralize(wing.errors.count, "error") %> prohibited this society from being saved:</h5>
              <ul>
                <% wing.errors.each do |error| %>
                  <li><%= error.full_message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="row g-3">
            <section>
              <%= hidden_field_tag :society_id, params[:society_id] %>
              <div class="col-12 mb-3">
                <label class="form-label">Name</label>
                <%= form.text_field :name, class: "form-control" %>
                <div class="invalid-feedback">
                  Valid name is required.
                </div>
              </div>
            </section>

            <div class="col-12">
              <button class="w-100 btn btn-primary btn-lg" type="submit">
                Add Wing
              </button>
            </div>
          </div>
        <% end %>
      </section>
    </div>
  </div>
</div>

