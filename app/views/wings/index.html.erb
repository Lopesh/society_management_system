<% content_for :datatable_header do %>
  <tr>
    <th>#</th>
    <th>Name</th>
    <th>Member Count</th>
  </tr>
<% end %>

<% content_for :datatable_body do %>
  <% @wings.each_with_index do |wing, index| %>
    <tr>
      <td><%= index + 1 %></td>
      <td><%= wing.name %></td>
      <td><%= wing.users.count %></td>
    </tr>
  <% end %>
<% end %>
<%= render 'layouts/datatable', header: "Wing", new_record_path: new_wing_path, is_new_button_visible: !current_user.super_admin? %>