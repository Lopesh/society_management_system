<%# --- Card Body Section --- %>
<% content_for :show_card_body do %>
  <% wing_presenter = WingPresenter.new(@wing)%>
  <div class="card-body">
    <dl class="row">
      <dt class="col-sm-4">Name</dt>
      <dd class="col-sm-8"><%= wing_presenter.display_text(@wing.name) %></dd>
    </dl>
  </div>
<% end %>

<%# --- Card Footer Section --- %>
<% content_for :show_card_footer do %>
  <%= link_to "Edit Wing", edit_wing_path(@wing), class: "btn btn-outline-primary" %>
  <%= link_to "Back to Wing", wings_path, class: "btn btn-secondary" %>
  <%= button_to "Destroy Wing", @wing, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger" %>
<% end %>

<% content_for :datatable_header do %>
  <tr>
    <th>#</th>
    <th>Name</th>
    <th>Email</th>
    <th>Phone</th>
  </tr>
<% end %>

<% content_for :datatable_body do %>
  <% @wing.users.each_with_index do |user, index| %>
    <tr>
      <td><%= index + 1 %></td>
      <td><%= user.name %></td>
      <td><%= user.email %></td>
      <td><%= user.phone %></td>
    </tr>
  <% end %>
<% end %>

<%= render "layouts/view_template", header: "Wing Details", table_header: "Member", new_record_path: new_user_path, is_new_button_visible: !current_user.super_admin? %>
